generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SemanticCache {
  id        Int      @id @default(autoincrement())
  command   String   @unique
  payload   String
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  role      String
  content   String
  createdAt DateTime @default(now())
}

model DashboardConfig {
  id           Int      @id @default(autoincrement())
  pages        String   @default("[]")
  activePageId String?
  updatedAt    DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model HASettings {
  id        Int      @id @default(autoincrement())
  haUrl     String
  haToken   String
  updatedAt DateTime @updatedAt
}
