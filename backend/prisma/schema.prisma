datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model SemanticCache {
  id        Int      @id @default(autoincrement())
  command   String   @unique
  payload   String   // JSON representing { domain, service, entity_id }
  hitCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
}

model DashboardConfig {
  id        Int      @id @default(1)
  widgets   String   // JSON string
  layout    String   // JSON string
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model HASettings {
  id        Int      @id @default(1)
  haUrl     String
  haToken   String
  updatedAt DateTime @updatedAt
}
